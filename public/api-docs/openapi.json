    "components": {
        "schemas": {
            "Task": {
                "properties": {
                    "id": {
                        "description": "Unique identifier for the task",
                        "type": "integer"
                    },
                    "task": {
                        "description": "Description of the task",
                        "type": "string"
                    },
                    "assigned_to": {
                        "description": "Team assigned to the task",
                        "type": "string"
                    },
                    "employee_responsible": {
                        "description": "Username of the employee responsible for the task",
                        "type": "string"
                    },
                    "status": {
                        "description": "Current status of the task (Pending, In Progress, Completed)",
                        "type": "string"
                    },
                    "created_at": {
                        "description": "Timestamp when the task was created",
                        "type": "string",
                        "format": "date-time"
                    },
                    "updated_at": {
                        "description": "Timestamp when the task was last updated",
                        "type": "string",
                        "format": "date-time"
                    }
                },
                "type": "object"
            },
            "User": {
                "properties": {
                    "id": {
                        "description": "Unique identifier for the user",
                        "type": "integer"
                    },
                    "username": {
                        "description": "Username of the user",
                        "type": "string"
                    },
                    "role": {
                        "description": "Role of the user (Admin, Manager, Employee)",
                        "type": "string"
                    },
                    "created_at": {
                        "description": "Timestamp when the user was created",
                        "type": "string",
                        "format": "date-time"
                    }
                },
                "type": "object"
            }
        },
        "securitySchemes": {
            "sessionAuth": {
                "type": "apiKey",
                "description": "Session-based authentication via PHP session cookie",
                "name": "PHPSESSID",
                "in": "cookie"
            }
        }
    },
